# LunVex API Key (uses DeepSeek API)
# Get your API key from: https://platform.deepseek.com/
LUNVEX_API_KEY=your_api_key_here

# For backward compatibility, you can also use:
# DEEPSEEK_API_KEY=your_api_key_here

# Optional: Override model (default: deepseek-chat)
# LUNVEX_MODEL=deepseek-chat
# or for backward compatibility: DEEPSEEK_MODEL=deepseek-chat

# Optional: Override base URL (default: https://api.deepseek.com)
# LUNVEX_BASE_URL=https://api.deepseek.com
# or for backward compatibility: DEEPSEEK_BASE_URL=https://api.deepseek.com
